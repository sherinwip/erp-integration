                "v1",
                "steps",
                "{{stepPk}}"
              ]
            }
          }
        },
        {
          "name": "Update Step",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"on_not_found\": \"skip\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/steps/{{stepPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "steps",
                "{{stepPk}}"
              ]
