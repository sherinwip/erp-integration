    {
      "name": "Pipelines",
      "item": [
        {
          "name": "List Pipelines",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipelines?client_id={{clientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipelines"
              ],
              "query": [
                {
                  "key": "client_id",
                  "value": "{{clientId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create Pipeline",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pipeline_id\": \"{{pipelineId}}\",\n  \"client_id\": \"{{clientId}}\",\n  \"version\": \"1.0\",\n  \"source_system\": \"salesforce\",\n  \"object_type\": \"ContractAward\",\n  \"event_type\": \"create\",\n  \"pattern_id\": \"PAT-03\",\n  \"status\": \"active\",\n  \"retry_max_attempts\": 3,\n  \"retry_backoff\": \"exponential\",\n  \"retry_backoff_base_ms\": 2000,\n  \"retry_on_status_codes\": \"500,502,503,504\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipelines",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipelines"
              ]
            }
          }
        },
        {
          "name": "Get Pipeline",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipelines/{{pipelineId}}",
