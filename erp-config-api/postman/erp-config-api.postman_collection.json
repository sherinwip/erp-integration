      "value": "AV"
    },
    {
      "key": "targetId",
      "value": "AV-oracle-fusion"
    },
    {
      "key": "stepPk",
      "value": "1"
    },
    {
      "key": "pipelineId",
      "value": "award-to-oracle-contract-v1"
