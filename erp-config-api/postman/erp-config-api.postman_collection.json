                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipelines",
                "{{pipelineId}}"
              ]
            }
          }
        },
        {
          "name": "Update Pipeline",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipelines/{{pipelineId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipelines",
                "{{pipelineId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Pipeline",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipelines/{{pipelineId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipelines",
                "{{pipelineId}}"
              ]
            }
          }
        },
        {
          "name": "Get Pipeline Steps (ordered)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipelines/{{pipelineId}}/steps",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipelines",
                "{{pipelineId}}",
                "steps"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Pipeline Steps (junction)",
      "item": [
        {
          "name": "Attach Step to Pipeline",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pipeline_id\": \"{{pipelineId}}\",\n  \"step_pk\": {{stepPk}},\n  \"seq\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipeline-steps",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipeline-steps"
              ]
            }
          }
        },
        {
          "name": "Get Pipeline Step Attachment",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipeline-steps/{{pipelineStepPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipeline-steps",
                "{{pipelineStepPk}}"
              ]
            }
          }
        },
        {
          "name": "Update Pipeline Step Seq",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seq\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipeline-steps/{{pipelineStepPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipeline-steps",
                "{{pipelineStepPk}}"
              ]
            }
          }
        },
        {
          "name": "Detach Step from Pipeline",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/pipeline-steps/{{pipelineStepPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pipeline-steps",
                "{{pipelineStepPk}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Field Mappings",
      "item": [
        {
          "name": "List Field Mappings for Step",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/field-mappings?step_pk={{stepPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "field-mappings"
              ],
              "query": [
                {
                  "key": "step_pk",
                  "value": "{{stepPk}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create Field Mapping",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"step_pk\": {{stepPk}},\n  \"source_path\": \"contract.name\",\n  \"target_path\": \"ContractName\",\n  \"transform_type\": \"none\",\n  \"is_required\": true,\n  \"sort_order\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/field-mappings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "field-mappings"
              ]
            }
          }
        },
        {
          "name": "Create Field Mappings (Bulk)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"step_pk\": {{stepPk}},\n  \"mappings\": [\n    {\n      \"source_path\": \"contract.name\",\n      \"target_path\": \"ContractName\",\n      \"transform_type\": \"none\",\n      \"is_required\": true,\n      \"sort_order\": 1\n    },\n    {\n      \"source_path\": \"contract.amount\",\n      \"target_path\": \"Amount\",\n      \"transform_type\": \"round\",\n      \"transform_params\": \"{\\\"decimals\\\": 2}\",\n      \"sort_order\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/field-mappings/bulk",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "field-mappings",
                "bulk"
              ]
            },
            "description": "Creates every mapping row for a step_pk in one request/transaction. All rows land or none do."
          }
        },
        {
          "name": "Get Field Mapping",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/field-mappings/{{mappingPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "field-mappings",
                "{{mappingPk}}"
              ]
            }
          }
        },
        {
          "name": "Update Field Mapping",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"default_value\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/field-mappings/{{mappingPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "field-mappings",
                "{{mappingPk}}"
              ]
            }
          }
        },
        {
          "name": "Delete Field Mapping",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/field-mappings/{{mappingPk}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "field-mappings",
                "{{mappingPk}}"
              ]
            }
          }
        }
      ]
    }
  ]
