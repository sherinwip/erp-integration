    {
      "name": "Steps",
      "item": [
        {
          "name": "List Steps",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/steps?client_id={{clientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "steps"
              ],
              "query": [
                {
                  "key": "client_id",
                  "value": "{{clientId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create Step",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"target_id\": \"{{targetId}}\",\n  \"step_name\": \"create-contract\",\n  \"method\": \"POST\",\n  \"path\": \"/fscmRestApi/resources/11.13.18.05/contracts\",\n  \"on_not_found\": \"fail\",\n  \"on_multiple_results\": \"useFirst\",\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/steps",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "steps"
              ]
            }
          }
        },
