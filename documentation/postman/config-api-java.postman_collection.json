              "raw": "{\n  \"step_pk\": \"{{demoStepPk}}\",\n  \"mappings\": [\n    {\n      \"source_path\": \"legalEntityName\",\n      \"target_path\": \"demo_legalEntityName_upper\",\n      \"transform_type\": \"uppercase\",\n      \"sort_order\": 901\n    },\n    {\n      \"source_path\": \"contractTypeName\",\n      \"target_path\": \"demo_contractTypeName_lower\",\n      \"transform_type\": \"lowercase\",\n      \"sort_order\": 902\n    },\n    {\n      \"source_path\": \"owningOrgName\",\n      \"target_path\": \"demo_owningOrgName_title\",\n      \"transform_type\": \"titlecase\",\n      \"sort_order\": 903\n    },\n    {\n      \"source_path\": \"customerPONumber\",\n      \"target_path\": \"demo_customerPONumber_trim\",\n      \"transform_type\": \"trim\",\n      \"sort_order\": 904\n    },\n    {\n      \"source_path\": \"contributionPercent\",\n      \"target_path\": \"demo_contributionPercent_round\",\n      \"transform_type\": \"round\",\n      \"sort_order\": 905,\n      \"transform_params\": \"{\\\"decimals\\\": 2}\"\n    },\n    {\n      \"source_path\": \"orgId\",\n      \"target_path\": \"demo_orgId_typecast_string\",\n      \"transform_type\": \"type_cast\",\n      \"sort_order\": 906,\n      \"transform_params\": \"{\\\"targetType\\\": \\\"string\\\"}\"\n    },\n    {\n      \"source_path\": \"contractNumber\",\n      \"target_path\": \"demo_contractNumber_replace\",\n      \"transform_type\": \"replace\",\n      \"sort_order\": 907,\n      \"transform_params\": \"{\\\"find\\\": \\\"_\\\", \\\"replace\\\": \\\"-\\\"}\"\n    },\n    {\n      \"source_path\": \"headerAttributes.masterContractNumber\",\n      \"target_path\": \"demo_masterContractNumber_splitpick\",\n      \"transform_type\": \"split_pick\",\n      \"sort_order\": 908,\n      \"transform_params\": \"{\\\"delimiter\\\": \\\"-\\\", \\\"index\\\": 1}\"\n    },\n    {\n      \"source_path\": \"startDate\",\n      \"target_path\": \"demo_startDate_dateadd\",\n      \"transform_type\": \"date_add\",\n      \"sort_order\": 909,\n      \"transform_params\": \"{\\\"unit\\\": \\\"months\\\", \\\"amount\\\": 1, \\\"outputFormat\\\": \\\"yyyy-MM-dd\\\"}\"\n    },\n    {\n      \"source_path\": \"headerAttributes.originalContractualDate\",\n      \"target_path\": \"demo_originalContractualDate_reformat\",\n      \"transform_type\": \"date_format\",\n      \"sort_order\": 910,\n      \"transform_params\": \"{\\\"outputFormat\\\": \\\"dd-MM-yyyy\\\"}\"\n    }\n  ]\n}"
