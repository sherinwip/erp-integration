                "v1",
                "targets"
              ]
            },
            "description": "PAT-02 (Sequential POST Chain): same client (request 1), a dedicated target for this demo.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target_id\": \"{{pat02TargetId}}\",\n  \"client_id\": \"{{demoClientId}}\",\n  \"target_name\": \"OracleFusionContractsPAT02\",\n  \"base_url\": \"https://ewnj-test.fa.us8.oraclecloud.com\",\n  \"auth_type\": \"oauth2\",\n  \"credential_ref\": \"oracle-ewnj-test-creds-pat02\",\n  \"default_headers\": {},\n  \"is_active\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "8.2 - Add Step 1 (create-contract-header)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
