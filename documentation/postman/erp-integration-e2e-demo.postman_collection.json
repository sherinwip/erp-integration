{
  "info": {
    "_postman_id": "5b3cd3f9-3eca-4238-87d3-05d3f7fa6ca1",
    "name": "erp-integration - Onboarding to Transform (E2E Demo)",
    "description": "End-to-end client onboarding flow: create client -> define target -> add step -> define pipeline -> attach step to pipeline -> add field mappings (one per supported transform_type) -> run the real transform via transformation-svc. Run top to bottom.\n\nRequires erp-config-api running on {{configApiBaseUrl}} (default http://localhost:8010) and transformation-svc running on {{transformSvcBaseUrl}} (default http://localhost:8000), both pointed at the same local Postgres.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 - Onboard Client",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{configApiBaseUrl}}/api/v1/clients",
          "host": [
            "{{configApiBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "clients"
          ]
        },
        "description": "Onboard the client tenant. Everything below (target, step, pipeline) hangs off this client_id.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"client_id\": \"{{demoClientId}}\",\n  \"client_name\": \"AeroVironment Demo\",\n  \"is_active\": true\n}"
        }
      },
      "response": []
    },
    {
      "name": "2 - Define Target (Oracle Fusion endpoint)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{configApiBaseUrl}}/api/v1/targets",
          "host": [
            "{{configApiBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "targets"
          ]
        },
        "description": "Define the ERP target (base_url + auth) this client's steps will call.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"target_id\": \"{{demoTargetId}}\",\n  \"client_id\": \"{{demoClientId}}\",\n  \"target_name\": \"OracleFusionContractsDemo\",\n  \"base_url\": \"https://ewnj-test.fa.us8.oraclecloud.com\",\n  \"auth_type\": \"oauth2\",\n  \"credential_ref\": \"oracle-ewnj-test-creds-demo\",\n  \"default_headers\": {},\n  \"is_active\": true\n}"
        }
      },
      "response": []
    },
    {
      "name": "3 - Add Step (create-oracle-contract)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{configApiBaseUrl}}/api/v1/steps",
          "host": [
            "{{configApiBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "steps"
          ]
        },
        "description": "Add the step (the HTTP call this pipeline will make). Copy the response's step_pk into the demoStepPk collection variable before running the next requests (or add a Tests script: pm.collectionVariables.set('demoStepPk', pm.response.json().step_pk)).",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"client_id\": \"{{demoClientId}}\",\n  \"target_id\": \"{{demoTargetId}}\",\n  \"step_name\": \"create-oracle-contract-demo\",\n  \"method\": \"POST\",\n  \"path\": \"/fscmRestApi/resources/11.13.18.05/contracts\",\n  \"is_active\": true\n}"
        }
      },
      "response": []
    },
    {
      "name": "4 - Define Pipeline (award-to-oracle-contract-demo-v1)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{configApiBaseUrl}}/api/v1/pipelines",
          "host": [
            "{{configApiBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "pipelines"
          ]
        },
        "description": "Define the pipeline routing key (source_system + object_type + event_type -> pipeline_id) a CRM caller would trigger.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pipeline_id\": \"{{demoPipelineId}}\",\n  \"client_id\": \"{{demoClientId}}\",\n  \"version\": \"1.0\",\n  \"source_system\": \"salesforce\",\n  \"object_type\": \"ContractAward\",\n  \"event_type\": \"createDemo\",\n  \"pattern_id\": \"PAT-01\",\n  \"status\": \"active\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "5 - Attach Step to Pipeline",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{configApiBaseUrl}}/api/v1/pipeline-steps",
          "host": [
            "{{configApiBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "pipeline-steps"
          ]
        },
        "description": "Attach the step created in request 3 to the pipeline as seq 1.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pipeline_id\": \"{{demoPipelineId}}\",\n  \"step_pk\": \"{{demoStepPk}}\",\n  \"seq\": 1\n}"
        }
      },
      "response": []
    },
    {
      "name": "6 - Add Field Mappings (bulk, one request for all transform_types)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{configApiBaseUrl}}/api/v1/field-mappings/bulk",
          "host": [
            "{{configApiBaseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "field-mappings",
            "bulk"
          ]
        },
        "description": "Adds all 10 field_mapping rows -- one per implemented transform_type (uppercase, lowercase, titlecase, trim, round, type_cast, replace, split_pick, date_add, date_format) -- in a single request/transaction against POST /api/v1/field-mappings/bulk. Hangs off {{demoStepPk}} from request 3.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"step_pk\": \"{{demoStepPk}}\",\n  \"mappings\": [\n    {\n      \"source_path\": \"legalEntityName\",\n      \"target_path\": \"demo_legalEntityName_upper\",\n      \"transform_type\": \"uppercase\",\n      \"sort_order\": 901\n    },\n    {\n      \"source_path\": \"contractTypeName\",\n      \"target_path\": \"demo_contractTypeName_lower\",\n      \"transform_type\": \"lowercase\",\n      \"sort_order\": 902\n    },\n    {\n      \"source_path\": \"owningOrgName\",\n      \"target_path\": \"demo_owningOrgName_title\",\n      \"transform_type\": \"titlecase\",\n      \"sort_order\": 903\n    },\n    {\n      \"source_path\": \"customerPONumber\",\n      \"target_path\": \"demo_customerPONumber_trim\",\n      \"transform_type\": \"trim\",\n      \"sort_order\": 904\n    },\n    {\n      \"source_path\": \"contributionPercent\",\n      \"target_path\": \"demo_contributionPercent_round\",\n      \"transform_type\": \"round\",\n      \"sort_order\": 905,\n      \"transform_params\": \"{\\\"decimals\\\": 2}\"\n    },\n    {\n      \"source_path\": \"orgId\",\n      \"target_path\": \"demo_orgId_typecast_string\",\n      \"transform_type\": \"type_cast\",\n      \"sort_order\": 906,\n      \"transform_params\": \"{\\\"targetType\\\": \\\"string\\\"}\"\n    },\n    {\n      \"source_path\": \"contractNumber\",\n      \"target_path\": \"demo_contractNumber_replace\",\n      \"transform_type\": \"replace\",\n      \"sort_order\": 907,\n      \"transform_params\": \"{\\\"find\\\": \\\"_\\\", \\\"replace\\\": \\\"-\\\"}\"\n    },\n    {\n      \"source_path\": \"headerAttributes.masterContractNumber\",\n      \"target_path\": \"demo_masterContractNumber_splitpick\",\n      \"transform_type\": \"split_pick\",\n      \"sort_order\": 908,\n      \"transform_params\": \"{\\\"delimiter\\\": \\\"-\\\", \\\"index\\\": 1}\"\n    },\n    {\n      \"source_path\": \"startDate\",\n      \"target_path\": \"demo_startDate_dateadd\",\n      \"transform_type\": \"date_add\",\n      \"sort_order\": 909,\n      \"transform_params\": \"{\\\"unit\\\": \\\"months\\\", \\\"amount\\\": 1, \\\"outputFormat\\\": \\\"yyyy-MM-dd\\\"}\"\n    },\n    {\n      \"source_path\": \"headerAttributes.originalContractualDate\",\n      \"target_path\": \"demo_originalContractualDate_reformat\",\n      \"transform_type\": \"date_format\",\n      \"sort_order\": 910,\n      \"transform_params\": \"{\\\"outputFormat\\\": \\\"dd-MM-yyyy\\\"}\"\n    }\n  ]\n}"
        }
      },
      "response": []
    },
