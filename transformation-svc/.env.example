# Local Docker Postgres defaults -- copy to .env and adjust for other environments.
# In production (Step Functions/Lambda) these come from Lambda environment
# variables populated from Secrets Manager/SSM, not a .env file.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_integration
DB_USER=root
DB_PASSWORD=root

HTTP_TIMEOUT_SECONDS=30

# Auth secrets, one env var per credential_ref (see erp_transform/auth.py).
# credential_ref "oracle-ewnj-test-creds" -> CRED_ORACLE_EWNJ_TEST_CREDS
# Value is a JSON blob; shape depends on auth_type:
#   oauth2: {"tokenUrl": "...", "clientId": "...", "clientSecret": "...", "scope": "..."}
#   basic:  {"username": "...", "password": "..."}
#   apikey: {"apiKey": "...", "headerName": "X-API-Key"}
# CRED_ORACLE_EWNJ_TEST_CREDS={"tokenUrl":"https://...","clientId":"...","clientSecret":"...","scope":"..."}
