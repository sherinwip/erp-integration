<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="004-create-table-step" author="erp-integration">
        <createTable tableName="step">
            <column name="step_pk" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="client_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="target_id" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="step_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="method" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="path" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="query_params" type="JSONB"/>
            <column name="headers" type="JSONB"/>
            <column name="extract" type="JSONB"/>
            <column name="on_not_found" type="VARCHAR(20)" defaultValue="fail">
                <constraints nullable="false"/>
            </column>
            <column name="on_multiple_results" type="VARCHAR(20)" defaultValue="useFirst">
                <constraints nullable="false"/>
            </column>
            <column name="rollback_method" type="VARCHAR(10)"/>
            <column name="rollback_path" type="VARCHAR(500)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="step" baseColumnNames="client_id"
            referencedTableName="client" referencedColumnNames="client_id"
            constraintName="fk_step_client"/>

        <addForeignKeyConstraint
            baseTableName="step" baseColumnNames="target_id"
            referencedTableName="target" referencedColumnNames="target_id"
            constraintName="fk_step_target"/>

        <addUniqueConstraint tableName="step" columnNames="client_id, step_name"
            constraintName="uq_step_client_name"/>

        <createIndex tableName="step" indexName="idx_step_target">
            <column name="target_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="004b-create-step-client-index" author="erp-integration">
        <sql>
            CREATE INDEX idx_step_client ON step (client_id) WHERE is_active = TRUE;
        </sql>
        <rollback>
            DROP INDEX IF EXISTS idx_step_client;
        </rollback>
    </changeSet>

</databaseChangeLog>
