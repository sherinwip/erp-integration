<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!--
        Seeds a real PAT-01 pipeline for the "Contract Creation Steps" Oracle Fusion
        contract-create endpoint (documentation/sample-payloads/oracle-fusion-contract-output.json).
        Assumed inbound Salesforce payload: documentation/sample-payloads/salesforce-contract-award-input.json.

        Demonstrates the array_source_path / array_target_path columns added in
        changeset 008: ContractHeaderFlexfieldVA and ContractParty are singleton/1-item
        arrays; ContractLine (with nested ContractAllLineDesFlexVA per line) is a true
        repeating array driven by source "lines[]".
    -->

    <changeSet id="009-seed-target-oracle-contracts" author="erp-integration" context="demo">
        <insert tableName="target">
            <column name="target_id" value="AV-oracle-fusion-contracts"/>
            <column name="client_id" value="AV"/>
            <column name="target_name" value="OracleFusionContracts"/>
            <column name="base_url" value="https://ewnj-test.fa.us8.oraclecloud.com"/>
            <column name="auth_type" value="oauth2"/>
            <column name="credential_ref" value="oracle-ewnj-test-creds"/>
        </insert>
    </changeSet>

    <changeSet id="009-seed-pipeline-oracle-contract" author="erp-integration" context="demo">
        <insert tableName="pipeline">
            <column name="pipeline_id" value="award-to-oracle-contract-full-v1"/>
            <column name="client_id" value="AV"/>
            <column name="source_system" value="salesforce"/>
            <column name="object_type" value="ContractAward"/>
            <column name="event_type" value="createFull"/>
